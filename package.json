{
  "name": "work-please",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:app": "turbo run lint --filter=@pleaseai/work",
    "lint:app:fix": "turbo run lint:fix --filter=@pleaseai/work",
    "check": "turbo run check",
    "check:app": "turbo run check --filter=@pleaseai/work",
    "test": "turbo run test",
    "test:app": "turbo run test --filter=@pleaseai/work",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "turbo": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "bun@1.3.10",
  "version": "1.0.0"
}
