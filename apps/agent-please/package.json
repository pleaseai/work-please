{
  "name": "@pleaseai/agent",
  "type": "module",
  "version": "0.1.21",
  "description": "Autonomous coding agent for GitHub, Linear, and Slack",
  "license": "FSL-1.1-MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/agent-please.git",
    "directory": "apps/agent-please"
  },
  "bin": {
    "agent": "./dist/index.js",
    "agent-please": "./dist/index.js",
    "agentplease": "./dist/index.js"
  },
  "files": [
    ".output",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE ../../README.md .",
    "postpublish": "rm -f LICENSE README.md",
    "build": "nuxt build && bun build ./src/index.ts --outdir ./dist --target bun && bun run scripts/add-shebang.ts",
    "dev": "nuxt dev --dotenv .env.local",
    "prepare": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=coverage/test-report.junit.xml"
  },
  "dependencies": {
    "@chat-adapter/github": "^4.20.2",
    "@chat-adapter/slack": "^4.20.2",
    "@chat-adapter/state-ioredis": "^4.20.2",
    "@chat-adapter/state-memory": "^4.20.2",
    "@chat-adapter/state-pg": "^4.20.2",
    "@chat-adapter/state-redis": "^4.20.2",
    "@nuxt/ui": "^4.5.1",
    "@octokit/graphql": "^9.0.3",
    "@pleaseai/agent-core": "workspace:*",
    "@vueuse/nuxt": "^14.2.1",
    "better-auth": "^1.5.5",
    "chat": "^4.20.2",
    "chat-adapter-asana": "^0.1.0",
    "commander": "^14.0.3",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "playwright-core": "^1.58.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
