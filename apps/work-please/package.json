{
  "name": "@pleaseai/work",
  "type": "module",
  "version": "0.1.12",
  "description": "Symphony-spec orchestrator for Claude Code + Asana/GitHub Projects v2",
  "license": "FSL-1.1-MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pleaseai/work-please.git",
    "directory": "apps/work-please"
  },
  "bin": {
    "work-please": "./dist/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE ../../README.md .",
    "postpublish": "rm -f LICENSE README.md",
    "build": "nuxt build && bun build ./src/index.ts --outdir ./dist --target bun && bun run scripts/add-shebang.ts",
    "dev": "nuxt dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov"
  },
  "dependencies": {
    "@nuxt/ui": "^4.5.1",
    "@octokit/graphql": "^9.0.3",
    "@pleaseai/core": "workspace:*",
    "commander": "^14.0.3",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "typescript": "^5.7.0"
  }
}
